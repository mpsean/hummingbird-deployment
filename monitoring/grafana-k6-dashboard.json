        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_payroll_bulk_duration{quantile='0.50'}", "legendFormat": "Payroll p50" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_http_req_duration{scenario='bulk_payroll',quantile='0.95'}", "legendFormat": "HTTP p95" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "vector(500)", "legendFormat": "SLA 500ms" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus{scenario='bulk_payroll'}", "legendFormat": "VUs" }
      ] },

    { "id": 22, "type": "stat", "title": "01 — Payroll p95 vs SLA", "gridPos": { "x": 16, "y": 14, "w": 4, "h": 4 },
