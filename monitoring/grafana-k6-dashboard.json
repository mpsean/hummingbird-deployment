{
  "title": "Hummingbird — k6 Load Test Monitor",
  "uid": "hummingbird-k6",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "description": "Infrastructure-focused testing on t3.medium. Pass criteria: availability, scaling events, recovery — not latency. Run: ./k6/run.sh k6/<scenario>.js",
  "panels": [

    { "id": 1, "type": "stat", "title": "Active VUs (all scenarios)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 8000 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "sum(k6_vus)", "legendFormat": "VUs" }] },

    { "id": 2, "type": "stat", "title": "Total Request Rate (req/s)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "blue", "value": null }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "sum(rate(k6_http_reqs_total[1m]))", "legendFormat": "RPS" }] },

    { "id": 3, "type": "stat", "title": "Overall Error Rate",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" },
        "expr": "avg(k6_http_req_failed_rate)",
        "legendFormat": "Error Rate" }] },

    { "id": 4, "type": "stat", "title": "API Ready Pods",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "blue", "value": 10 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" },
        "expr": "kube_deployment_status_replicas_ready{deployment='hummingbird-api', namespace='hummingbird-api'}",
        "legendFormat": "Ready Replicas" }] },

    { "id": 5, "type": "timeseries", "title": "VUs per Scenario",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 5 }, "color": { "mode": "palette-classic" } } },
      "targets": [
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus", "legendFormat": "Active VUs" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus_max", "legendFormat": "Max VUs (scenario ceiling)" }
      ] },

    { "id": 10, "type": "row", "title": "Scenario 00 — Regular Load (Baseline)  |  PASS: error < 5%, HPA must NOT fire  |  75 RPS target (t3.medium API + t3.xlarge postgres)", "collapsed": false, "gridPos": { "x": 0, "y": 4, "w": 24, "h": 1 } },

    { "id": 11, "type": "timeseries", "title": "00 — Response Time by Action (p95)",
      "gridPos": { "x": 0, "y": 5, "w": 16, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 }, "color": { "mode": "palette-classic" } },
        "overrides": [{ "matcher": { "id": "byName", "options": "SLA 300ms" }, "properties": [
          { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } },
          { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
        ]}] },
      "targets": [
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_baseline_list_duration_p95", "legendFormat": "List Employees p95" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_baseline_detail_duration_p95", "legendFormat": "Get Employee p95" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_baseline_payroll_duration_p95", "legendFormat": "Payroll Fetch p95" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_baseline_attendance_duration_p95", "legendFormat": "Attendance p95" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "vector(0.3)", "legendFormat": "SLA 300ms" }
      ] },

    { "id": 12, "type": "stat", "title": "00 — Error Rate (pass < 5%)", "gridPos": { "x": 16, "y": 5, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 0.03 }, { "color": "red", "value": 0.05 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_baseline_errors_rate", "legendFormat": "Error Rate" }] },

    { "id": 13, "type": "stat", "title": "00 — API Pods (live — must stay ≤ 16 during test)", "gridPos": { "x": 20, "y": 5, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 17 }, { "color": "red", "value": 24 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "kube_deployment_status_replicas_ready{deployment='hummingbird-api', namespace='hummingbird-api'}", "legendFormat": "Replicas" }] },

    { "id": 14, "type": "stat", "title": "00 — Achieved RPS", "gridPos": { "x": 16, "y": 9, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [
        { "color": "red", "value": null }, { "color": "yellow", "value": 55 }, { "color": "green", "value": 68 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "sum(rate(k6_http_reqs_total{scenario='ordinary_working_day'}[1m]))", "legendFormat": "RPS" }] },

    { "id": 15, "type": "stat", "title": "00 — Peak VUs", "gridPos": { "x": 20, "y": 9, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["max"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus", "legendFormat": "VUs" }] },

    { "id": 16, "type": "timeseries", "title": "00 — System: API CPU per Pod & Replica Count  (expect: CPU ≤ 40%, pods stable at minimum)",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 6 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "lineWidth": 2, "fillOpacity": 8 }, "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Ready Pods" }, "properties": [
            { "id": "unit", "value": "short" }, { "id": "custom.axisPlacement", "value": "right" },
            { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }
          ]},
          { "matcher": { "id": "byName", "options": "HPA 50% Threshold" }, "properties": [
            { "id": "custom.lineStyle", "value": { "dash": [6, 3], "fill": "dash" } },
            { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
          ]}
        ] },
      "targets": [
        { "datasource": { "uid": "PBFA97CFB590B2093" },
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace='hummingbird-api', container='api'}[2m])) / sum(kube_pod_container_resource_requests{namespace='hummingbird-api', container='api', resource='cpu'}) * 100",
          "legendFormat": "Avg CPU % (vs requests)" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "vector(50)", "legendFormat": "HPA 50% Threshold" },
        { "datasource": { "uid": "PBFA97CFB590B2093" },
          "expr": "kube_deployment_status_replicas_ready{deployment='hummingbird-api', namespace='hummingbird-api'}",
          "legendFormat": "Ready Pods" }
      ] },

    { "id": 20, "type": "row", "title": "Scenario 02 — Payroll Bulk Processing  |  PASS: error < 5%, HPA fires within 90 s  |  1 000 VUs peak", "collapsed": false, "gridPos": { "x": 0, "y": 40, "w": 24, "h": 1 } },

    { "id": 21, "type": "timeseries", "title": "02 — Payroll Calculate Duration & VUs",
      "gridPos": { "x": 0, "y": 41, "w": 16, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 }, "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "SLA 500ms" }, "properties": [
            { "id": "custom.lineStyle", "value": { "dash": [8,4], "fill": "dash" } },
            { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
          ]},
          { "matcher": { "id": "byName", "options": "VUs" }, "properties": [
            { "id": "unit", "value": "short" }, { "id": "custom.axisPlacement", "value": "right" }
          ]}
        ] },
      "targets": [
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_payroll_bulk_duration_p95", "legendFormat": "Payroll p95" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_payroll_bulk_duration_p50", "legendFormat": "Payroll p50" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_http_req_duration_p95", "legendFormat": "HTTP p95" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "vector(0.5)", "legendFormat": "SLA 500ms" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus", "legendFormat": "VUs" }
      ] },

    { "id": 22, "type": "stat", "title": "02 — HPA Fired (replicas > min)", "gridPos": { "x": 16, "y": 41, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["max"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [
        { "color": "red", "value": null }, { "color": "yellow", "value": 9 }, { "color": "green", "value": 12 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "kube_deployment_status_replicas_ready{deployment='hummingbird-api', namespace='hummingbird-api'}", "legendFormat": "Max Replicas" }] },

    { "id": 23, "type": "stat", "title": "02 — Error Rate (pass < 20%)", "gridPos": { "x": 20, "y": 41, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 0.15 }, { "color": "red", "value": 0.20 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_payroll_errors_rate", "legendFormat": "Error Rate" }] },

    { "id": 24, "type": "stat", "title": "02 — Peak VUs", "gridPos": { "x": 16, "y": 45, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["max"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus", "legendFormat": "VUs" }] },

    { "id": 25, "type": "stat", "title": "02 — Throughput", "gridPos": { "x": 20, "y": 45, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "sum(rate(k6_http_reqs_total{scenario='bulk_payroll'}[1m]))", "legendFormat": "RPS" }] },

    { "id": 26, "type": "timeseries", "title": "02 — System: API CPU % & Pods  (HPA fires at 50% avg CPU — spike to 10 000 VUs will breach threshold)",
      "gridPos": { "x": 0, "y": 49, "w": 24, "h": 6 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "lineWidth": 2, "fillOpacity": 8 }, "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Ready Pods" }, "properties": [
            { "id": "unit", "value": "short" }, { "id": "custom.axisPlacement", "value": "right" },
            { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }
          ]},
          { "matcher": { "id": "byName", "options": "HPA 50% Threshold" }, "properties": [
            { "id": "custom.lineStyle", "value": { "dash": [6, 3], "fill": "dash" } },
            { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
          ]},
          { "matcher": { "id": "byName", "options": "API Memory (MiB)" }, "properties": [
            { "id": "unit", "value": "decmbytes" }, { "id": "custom.axisPlacement", "value": "right" },
            { "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }
          ]}
        ] },
      "targets": [
        { "datasource": { "uid": "PBFA97CFB590B2093" },
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace='hummingbird-api', container='api'}[2m])) / sum(kube_pod_container_resource_requests{namespace='hummingbird-api', container='api', resource='cpu'}) * 100",
          "legendFormat": "Avg CPU % (vs requests)" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "vector(50)", "legendFormat": "HPA 50% Threshold" },
        { "datasource": { "uid": "PBFA97CFB590B2093" },
          "expr": "kube_deployment_status_replicas_ready{deployment='hummingbird-api', namespace='hummingbird-api'}",
          "legendFormat": "Ready Pods" },
        { "datasource": { "uid": "PBFA97CFB590B2093" },
          "expr": "sum(container_memory_working_set_bytes{namespace='hummingbird-api', container='api'}) / 1024 / 1024",
          "legendFormat": "API Memory (MiB)" }
      ] },

    { "id": 30, "type": "row", "title": "Scenario 01 — New Tenant Onboarding (sequential, 5 tenants)  |  PASS: error < 5%, all 5 tenants complete provisioning + data append  |  1 VU × 5 iterations", "collapsed": false, "gridPos": { "x": 0, "y": 19, "w": 24, "h": 1 } },

    { "id": 31, "type": "timeseries", "title": "01 — Step Durations Over Time (5 sequential tenants — visible as 5 spikes)",
      "gridPos": { "x": 0, "y": 20, "w": 16, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 }, "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Total Completion" }, "properties": [
            { "id": "custom.lineWidth", "value": 3 },
            { "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }
          ]}
        ] },
      "targets": [
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "avg(k6_tenant_provision_duration_avg)",  "legendFormat": "Provision (step 1)" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "avg(k6_tenant_employees_duration_avg)", "legendFormat": "Employees Import (step 2)" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "avg(k6_tenant_attendance_duration_avg)","legendFormat": "Attendance Import (step 3)" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "avg(k6_tenant_completion_duration_avg)","legendFormat": "Total Completion" }
      ] },

    { "id": 32, "type": "stat", "title": "01 — Avg Provision", "gridPos": { "x": 16, "y": 20, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 60 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "avg(k6_tenant_provision_duration_avg)", "legendFormat": "Provision" }] },

    { "id": 33, "type": "stat", "title": "01 — Avg Append (Emp+Att)", "gridPos": { "x": 20, "y": 20, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 300 }, { "color": "red", "value": 600 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "avg(k6_tenant_append_duration_avg)", "legendFormat": "Append" }] },

    { "id": 34, "type": "stat", "title": "01 — Avg Total Completion", "gridPos": { "x": 16, "y": 24, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 360 }, { "color": "red", "value": 720 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "avg(k6_tenant_completion_duration_avg)", "legendFormat": "Total" }] },

    { "id": 35, "type": "stat", "title": "01 — Error Rate (pass < 5%)", "gridPos": { "x": 20, "y": 24, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 0.03 }, { "color": "red", "value": 0.05 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_onboarding_errors_rate", "legendFormat": "Error Rate" }] },

    { "id": 36, "type": "bargauge", "title": "01 — Per-Tenant Provision Time  (just step 1 — DB + K8s namespace + ingress)",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 6 },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 60 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_tenant_provision_duration_avg", "legendFormat": "{{tenant}}" }] },

    { "id": 37, "type": "bargauge", "title": "01 — Per-Tenant Full Completion  (provision + employees + attendance)",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 6 },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 360 }, { "color": "red", "value": 720 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_tenant_completion_duration_avg", "legendFormat": "{{tenant}}" }] },

    { "id": 38, "type": "timeseries", "title": "01 — System: API CPU & Memory + Postgres CPU  (provisioning DDL hits postgres; CSV imports stress API memory + DB writes)",
      "gridPos": { "x": 0, "y": 34, "w": 24, "h": 6 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "lineWidth": 2, "fillOpacity": 8 }, "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "API Memory (MiB)" }, "properties": [
            { "id": "unit", "value": "decmbytes" }, { "id": "custom.axisPlacement", "value": "right" },
            { "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }
          ]}
        ] },
      "targets": [
        { "datasource": { "uid": "PBFA97CFB590B2093" },
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace='hummingbird-api', container='api'}[2m])) / sum(kube_pod_container_resource_requests{namespace='hummingbird-api', container='api', resource='cpu'}) * 100",
          "legendFormat": "API CPU %" },
        { "datasource": { "uid": "PBFA97CFB590B2093" },
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace='postgres', container='postgres'}[2m])) / sum(kube_pod_container_resource_requests{namespace='postgres', container='postgres', resource='cpu'}) * 100",
          "legendFormat": "Postgres CPU %" },
