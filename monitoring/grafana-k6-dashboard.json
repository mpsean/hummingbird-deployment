{
  "title": "Hummingbird — k6 Load Test Monitor",
  "uid": "hummingbird-k6",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "description": "Infrastructure-focused testing on t3.medium. Pass criteria: availability, scaling events, recovery — not latency. Run: ./k6/run.sh k6/<scenario>.js",
  "panels": [

    { "id": 1, "type": "stat", "title": "Active VUs (all scenarios)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 8000 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "sum(k6_vus)", "legendFormat": "VUs" }] },

    { "id": 2, "type": "stat", "title": "Total Request Rate (req/s)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "blue", "value": null }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "sum(rate(k6_http_reqs_total[1m]))", "legendFormat": "RPS" }] },

    { "id": 3, "type": "stat", "title": "Overall Error Rate",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" },
        "expr": "sum(rate(k6_http_reqs_total{expected_response='false'}[1m])) / sum(rate(k6_http_reqs_total[1m]))",
        "legendFormat": "Error Rate" }] },

    { "id": 4, "type": "stat", "title": "API Ready Replicas",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "blue", "value": 10 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" },
        "expr": "kube_deployment_status_replicas_ready{deployment='hummingbird-api', namespace='hummingbird-api'}",
        "legendFormat": "Ready Replicas" }] },

    { "id": 5, "type": "timeseries", "title": "VUs per Scenario",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 5 }, "color": { "mode": "palette-classic" } } },
      "targets": [
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus{scenario='ordinary_working_day'}", "legendFormat": "00 Baseline" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus{scenario='bulk_payroll'}", "legendFormat": "01 Payroll Bulk" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus{scenario='tenant_onboarding'}", "legendFormat": "02 Onboarding" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus{scenario='seasonal_staff'}", "legendFormat": "03 Seasonal Staff" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus{scenario='hpa_trigger'}", "legendFormat": "04 HPA Trigger" }
      ] },

    { "id": 10, "type": "row", "title": "Scenario 00 — Regular Load (Baseline)  |  PASS: error < 5%, HPA must NOT fire  |  50 RPS target (t3.medium sustainable)", "collapsed": false, "gridPos": { "x": 0, "y": 4, "w": 24, "h": 1 } },

    { "id": 11, "type": "timeseries", "title": "00 — Response Time by Action (p95)",
      "gridPos": { "x": 0, "y": 5, "w": 16, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 5 }, "color": { "mode": "palette-classic" } },
        "overrides": [{ "matcher": { "id": "byName", "options": "SLA 300ms" }, "properties": [
          { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } },
          { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
        ]}] },
      "targets": [
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_baseline_list_duration{quantile='0.95'}", "legendFormat": "List Employees p95" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_baseline_detail_duration{quantile='0.95'}", "legendFormat": "Get Employee p95" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_baseline_payroll_duration{quantile='0.95'}", "legendFormat": "Payroll Fetch p95" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_baseline_attendance_duration{quantile='0.95'}", "legendFormat": "Attendance p95" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "vector(300)", "legendFormat": "SLA 300ms" }
      ] },

    { "id": 12, "type": "stat", "title": "00 — Error Rate (pass < 5%)", "gridPos": { "x": 16, "y": 5, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 0.03 }, { "color": "red", "value": 0.05 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_baseline_errors{scenario='ordinary_working_day'}", "legendFormat": "Error Rate" }] },

    { "id": 13, "type": "stat", "title": "00 — HPA Fired? (should be 0)", "gridPos": { "x": 20, "y": 5, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["max"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "red", "value": 9 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "kube_deployment_status_replicas_ready{deployment='hummingbird-api', namespace='hummingbird-api'}", "legendFormat": "Replicas" }] },

    { "id": 14, "type": "stat", "title": "00 — Achieved RPS", "gridPos": { "x": 16, "y": 9, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [
        { "color": "red", "value": null }, { "color": "yellow", "value": 30 }, { "color": "green", "value": 45 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "sum(rate(k6_http_reqs_total{scenario='ordinary_working_day'}[1m]))", "legendFormat": "RPS" }] },

    { "id": 15, "type": "stat", "title": "00 — Peak VUs", "gridPos": { "x": 20, "y": 9, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["max"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus{scenario='ordinary_working_day'}", "legendFormat": "VUs" }] },

    { "id": 16, "type": "timeseries", "title": "00 — System: API CPU per Pod & Replica Count  (expect: CPU ≤ 40%, replicas stable at minimum)",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 6 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "lineWidth": 2, "fillOpacity": 8 }, "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Ready Replicas" }, "properties": [
            { "id": "unit", "value": "short" }, { "id": "custom.axisPlacement", "value": "right" },
            { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }
          ]},
          { "matcher": { "id": "byName", "options": "HPA 50% Threshold" }, "properties": [
            { "id": "custom.lineStyle", "value": { "dash": [6, 3], "fill": "dash" } },
            { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
          ]}
        ] },
      "targets": [
        { "datasource": { "uid": "PBFA97CFB590B2093" },
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace='hummingbird-api', container='api'}[2m])) / sum(kube_pod_container_resource_requests{namespace='hummingbird-api', container='api', resource='cpu'}) * 100",
          "legendFormat": "Avg CPU % (vs requests)" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "vector(50)", "legendFormat": "HPA 50% Threshold" },
        { "datasource": { "uid": "PBFA97CFB590B2093" },
          "expr": "kube_deployment_status_replicas_ready{deployment='hummingbird-api', namespace='hummingbird-api'}",
          "legendFormat": "Ready Replicas" }
      ] },

    { "id": 20, "type": "row", "title": "Scenario 01 — Payroll Bulk Processing  |  PASS: error < 20%, HPA fires within 90 s  |  1 000 VUs peak (t3.medium)", "collapsed": false, "gridPos": { "x": 0, "y": 19, "w": 24, "h": 1 } },

    { "id": 21, "type": "timeseries", "title": "01 — Payroll Calculate Duration & VUs",
      "gridPos": { "x": 0, "y": 20, "w": 16, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 5 }, "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "SLA 500ms" }, "properties": [
            { "id": "custom.lineStyle", "value": { "dash": [8,4], "fill": "dash" } },
            { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
          ]},
          { "matcher": { "id": "byName", "options": "VUs" }, "properties": [
            { "id": "unit", "value": "short" }, { "id": "custom.axisPlacement", "value": "right" }
          ]}
        ] },
      "targets": [
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_payroll_bulk_duration{quantile='0.95'}", "legendFormat": "Payroll p95" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_payroll_bulk_duration{quantile='0.50'}", "legendFormat": "Payroll p50" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_http_req_duration{scenario='bulk_payroll',quantile='0.95'}", "legendFormat": "HTTP p95" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "vector(500)", "legendFormat": "SLA 500ms" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus{scenario='bulk_payroll'}", "legendFormat": "VUs" }
      ] },

    { "id": 22, "type": "stat", "title": "01 — HPA Fired (replicas > min)", "gridPos": { "x": 16, "y": 20, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["max"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [
        { "color": "red", "value": null }, { "color": "yellow", "value": 9 }, { "color": "green", "value": 12 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "kube_deployment_status_replicas_ready{deployment='hummingbird-api', namespace='hummingbird-api'}", "legendFormat": "Max Replicas" }] },

    { "id": 23, "type": "stat", "title": "01 — Error Rate (pass < 20%)", "gridPos": { "x": 20, "y": 20, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 0.15 }, { "color": "red", "value": 0.20 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_payroll_errors{scenario='bulk_payroll'}", "legendFormat": "Error Rate" }] },

    { "id": 24, "type": "stat", "title": "01 — Peak VUs", "gridPos": { "x": 16, "y": 24, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["max"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus{scenario='bulk_payroll'}", "legendFormat": "VUs" }] },

    { "id": 25, "type": "stat", "title": "01 — Throughput", "gridPos": { "x": 20, "y": 24, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "sum(rate(k6_http_reqs_total{scenario='bulk_payroll'}[1m]))", "legendFormat": "RPS" }] },

    { "id": 26, "type": "timeseries", "title": "01 — System: API CPU % & Replicas  (HPA fires at 50% avg CPU — spike to 10 000 VUs will breach threshold)",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 6 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "lineWidth": 2, "fillOpacity": 8 }, "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Ready Replicas" }, "properties": [
            { "id": "unit", "value": "short" }, { "id": "custom.axisPlacement", "value": "right" },
            { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }
          ]},
          { "matcher": { "id": "byName", "options": "HPA 50% Threshold" }, "properties": [
            { "id": "custom.lineStyle", "value": { "dash": [6, 3], "fill": "dash" } },
            { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
          ]},
          { "matcher": { "id": "byName", "options": "API Memory (MiB)" }, "properties": [
            { "id": "unit", "value": "decmbytes" }, { "id": "custom.axisPlacement", "value": "right" },
            { "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }
          ]}
        ] },
      "targets": [
        { "datasource": { "uid": "PBFA97CFB590B2093" },
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace='hummingbird-api', container='api'}[2m])) / sum(kube_pod_container_resource_requests{namespace='hummingbird-api', container='api', resource='cpu'}) * 100",
          "legendFormat": "Avg CPU % (vs requests)" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "vector(50)", "legendFormat": "HPA 50% Threshold" },
        { "datasource": { "uid": "PBFA97CFB590B2093" },
          "expr": "kube_deployment_status_replicas_ready{deployment='hummingbird-api', namespace='hummingbird-api'}",
          "legendFormat": "Ready Replicas" },
        { "datasource": { "uid": "PBFA97CFB590B2093" },
          "expr": "sum(container_memory_working_set_bytes{namespace='hummingbird-api', container='api'}) / 1024 / 1024",
          "legendFormat": "API Memory (MiB)" }
      ] },

    { "id": 30, "type": "row", "title": "Scenario 02 — New Tenant Onboarding  |  PASS: provision p95 < 10 s, error < 5%  |  50 VUs, each provisions a full DB schema", "collapsed": false, "gridPos": { "x": 0, "y": 34, "w": 24, "h": 1 } },

    { "id": 31, "type": "timeseries", "title": "02 — Provision Duration & VUs",
      "gridPos": { "x": 0, "y": 35, "w": 16, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 5 }, "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "SLA 1000ms" }, "properties": [
            { "id": "custom.lineStyle", "value": { "dash": [8,4], "fill": "dash" } },
            { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
          ]},
          { "matcher": { "id": "byName", "options": "VUs" }, "properties": [
            { "id": "unit", "value": "short" }, { "id": "custom.axisPlacement", "value": "right" }
          ]}
        ] },
      "targets": [
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_onboarding_provision_duration{quantile='0.95'}", "legendFormat": "Provision p95" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_onboarding_provision_duration{quantile='0.50'}", "legendFormat": "Provision p50" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "vector(1000)", "legendFormat": "SLA 1000ms" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus{scenario='tenant_onboarding'}", "legendFormat": "VUs" }
      ] },

    { "id": 32, "type": "stat", "title": "02 — Provision p95 (pass < 10 s)", "gridPos": { "x": 16, "y": 35, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 7000 }, { "color": "red", "value": 10000 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_onboarding_provision_duration{quantile='0.95'}", "legendFormat": "p95" }] },

    { "id": 33, "type": "stat", "title": "02 — Error Rate (pass < 5%)", "gridPos": { "x": 20, "y": 35, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 0.03 }, { "color": "red", "value": 0.05 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_onboarding_errors{scenario='tenant_onboarding'}", "legendFormat": "Error Rate" }] },

    { "id": 34, "type": "stat", "title": "02 — Load-test Namespaces Created", "gridPos": { "x": 16, "y": 39, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" },
        "expr": "count(kube_namespace_status_phase{namespace=~'tenant-load-.*', phase='Active'})",
        "legendFormat": "Namespaces" }] },

    { "id": 35, "type": "stat", "title": "02 — Active VUs", "gridPos": { "x": 20, "y": 39, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus{scenario='tenant_onboarding'}", "legendFormat": "VUs" }] },

    { "id": 36, "type": "timeseries", "title": "02 — System: API Memory Growth & Namespace Count  (schema creation is memory-intensive — each provisioned DB inflates API memory)",
      "gridPos": { "x": 0, "y": 43, "w": 24, "h": 6 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "decmbytes", "custom": { "lineWidth": 2, "fillOpacity": 8 }, "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Load-test Namespaces" }, "properties": [
            { "id": "unit", "value": "short" }, { "id": "custom.axisPlacement", "value": "right" },
            { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }
          ]},
          { "matcher": { "id": "byName", "options": "API CPU %" }, "properties": [
            { "id": "unit", "value": "percent" }, { "id": "custom.axisPlacement", "value": "right" },
            { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
          ]}
        ] },
      "targets": [
        { "datasource": { "uid": "PBFA97CFB590B2093" },
          "expr": "sum(container_memory_working_set_bytes{namespace='hummingbird-api', container='api'}) / 1024 / 1024",
          "legendFormat": "API Memory (MiB)" },
        { "datasource": { "uid": "PBFA97CFB590B2093" },
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace='hummingbird-api', container='api'}[2m])) / sum(kube_pod_container_resource_requests{namespace='hummingbird-api', container='api', resource='cpu'}) * 100",
          "legendFormat": "API CPU %" },
        { "datasource": { "uid": "PBFA97CFB590B2093" },
          "expr": "count(kube_namespace_status_phase{namespace=~'tenant-load-.*', phase='Active'})",
          "legendFormat": "Load-test Namespaces" }
      ] },

