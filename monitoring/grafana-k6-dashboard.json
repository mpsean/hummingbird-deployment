{
  "title": "Hummingbird — k6 Load Test Monitor",
  "uid": "hummingbird-k6",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "description": "Run k6 with: K6_PROMETHEUS_RW_SERVER_URL=http://prometheus:9090/api/v1/write k6 run --out=experimental-prometheus-rw k6/<scenario>.js",
  "panels": [

    { "id": 1, "type": "stat", "title": "Active VUs (all scenarios)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 8000 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "sum(k6_vus)", "legendFormat": "VUs" }] },

    { "id": 2, "type": "stat", "title": "Total Request Rate (req/s)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "blue", "value": null }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "sum(rate(k6_http_reqs_total[1m]))", "legendFormat": "RPS" }] },

    { "id": 3, "type": "stat", "title": "Overall Error Rate",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" },
        "expr": "sum(rate(k6_http_reqs_total{expected_response='false'}[1m])) / sum(rate(k6_http_reqs_total[1m]))",
        "legendFormat": "Error Rate" }] },

    { "id": 4, "type": "stat", "title": "API Replicas",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 4 }, { "color": "blue", "value": 8 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" },
        "expr": "kube_deployment_status_replicas_ready{deployment='hummingbird-api', namespace='hummingbird-api'}",
        "legendFormat": "Ready Replicas" }] },

    { "id": 5, "type": "timeseries", "title": "VUs per Scenario",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 5 }, "color": { "mode": "palette-classic" } } },
      "targets": [
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus{scenario='ordinary_working_day'}", "legendFormat": "00 Baseline" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus{scenario='bulk_payroll'}", "legendFormat": "01 Payroll Bulk" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus{scenario='tenant_onboarding'}", "legendFormat": "02 Onboarding" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus{scenario='seasonal_staff'}", "legendFormat": "03 Seasonal Staff" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus{scenario='hpa_trigger'}", "legendFormat": "04 HPA Trigger" }
      ] },

    { "id": 10, "type": "row", "title": "Scenario 00 — Regular Load (Baseline)  |  SLA: p95 < 300 ms, error < 0.5%", "collapsed": false, "gridPos": { "x": 0, "y": 4, "w": 24, "h": 1 } },

    { "id": 11, "type": "timeseries", "title": "00 — Response Time by Action (p95)",
      "gridPos": { "x": 0, "y": 5, "w": 16, "h": 8 },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 5 }, "color": { "mode": "palette-classic" } },
        "overrides": [{ "matcher": { "id": "byName", "options": "SLA 300ms" }, "properties": [
          { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } },
          { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
        ]}] },
      "targets": [
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_baseline_list_duration{quantile='0.95'}", "legendFormat": "List Employees p95" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_baseline_detail_duration{quantile='0.95'}", "legendFormat": "Get Employee p95" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_baseline_payroll_duration{quantile='0.95'}", "legendFormat": "Payroll Fetch p95" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_baseline_attendance_duration{quantile='0.95'}", "legendFormat": "Attendance p95" },
        { "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "vector(300)", "legendFormat": "SLA 300ms" }
      ] },

    { "id": 12, "type": "stat", "title": "00 — Error Rate", "gridPos": { "x": 16, "y": 5, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "red", "value": 0.005 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_baseline_errors{scenario='ordinary_working_day'}", "legendFormat": "Error Rate" }] },

    { "id": 13, "type": "stat", "title": "00 — List Employees p95", "gridPos": { "x": 20, "y": 5, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "ms", "thresholds": { "mode": "absolute", "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 300 }
      ] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_baseline_list_duration{quantile='0.95'}", "legendFormat": "p95" }] },

    { "id": 14, "type": "stat", "title": "00 — Request Rate", "gridPos": { "x": 16, "y": 9, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "sum(rate(k6_http_reqs_total{scenario='ordinary_working_day'}[1m]))", "legendFormat": "RPS" }] },

    { "id": 15, "type": "stat", "title": "00 — Peak VUs", "gridPos": { "x": 20, "y": 9, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["max"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "targets": [{ "datasource": { "uid": "PBFA97CFB590B2093" }, "expr": "k6_vus{scenario='ordinary_working_day'}", "legendFormat": "VUs" }] },

    { "id": 20, "type": "row", "title": "Scenario 01 — Payroll Bulk Processing  |  SLA: p95 < 500 ms, error < 1%", "collapsed": false, "gridPos": { "x": 0, "y": 13, "w": 24, "h": 1 } },

